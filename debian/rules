#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	install -d $(CURDIR)/debian/nepali-calendar/usr/share/nepali-calendar
	cp -r nepali_calendar $(CURDIR)/debian/nepali-calendar/usr/share/nepali-calendar/
	if [ -d nepali_calendar/vendor ]; then \
		cp -r nepali_calendar/vendor $(CURDIR)/debian/nepali-calendar/usr/share/nepali-calendar/; \
	fi
	install -d $(CURDIR)/debian/nepali-calendar/usr/bin
	install -m 755 scripts/nepali-calendar.sh \
		$(CURDIR)/debian/nepali-calendar/usr/bin/nepali-calendar
	install -d $(CURDIR)/debian/nepali-calendar/usr/share/applications
	install -m 644 data/nepali.calendar.desktop \
		$(CURDIR)/debian/nepali-calendar/usr/share/applications/
	install -d $(CURDIR)/debian/nepali-calendar/usr/share/icons/hicolor/scalable/apps
	install -m 644 data/icons/nepali-calendar.svg \
		$(CURDIR)/debian/nepali-calendar/usr/share/icons/hicolor/scalable/apps/

override_dh_auto_test:
	# Skip tests
